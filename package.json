{
  "name": "extractor-bancario",
  "version": "1.0.0",
  "description": "Motor de procesamiento de extractos bancarios argentinos",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "server": "ts-node server/http-server.ts",
    "server:prod": "node dist/server/http-server.js",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "pdf-parse": "^1.1.1",
    "tesseract.js": "^5.0.5",
    "xlsx": "^0.18.5",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/cors": "^2.8.17",
    "@types/pdf-parse": "^1.1.4",
    "@types/node": "^20.11.5",
    "@types/jest": "^29.5.11",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.ts"],
    "moduleFileExtensions": ["ts", "js"],
    "collectCoverageFrom": ["src/**/*.ts"]
  }
}
